# ============================================================================
# GEMATRIA BOT - VARIABLES DE ENTORNO
# ============================================================================
# Copiar este archivo a .env y completar los valores
# ============================================================================

# ----------------------------------------------------------------------------
# SERVIDOR
# ----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# ----------------------------------------------------------------------------
# SUPABASE
# ----------------------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ----------------------------------------------------------------------------
# OPENAI
# ----------------------------------------------------------------------------
OPENAI_API_KEY=<openai-api-key>

# ----------------------------------------------------------------------------
# MERCADO PAGO (Latinoamérica)
# ----------------------------------------------------------------------------
# Obtener de: https://www.mercadopago.com/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Webhook secret (configurar en panel de MP)
MERCADOPAGO_WEBHOOK_SECRET=

# Moneda para planes creados vía script setup-plans (ARS, BRL, MXN, etc.)
MERCADOPAGO_CURRENCY_ID=ARS

# Precios específicos de MP (en moneda local, sin centavos)
# Si no se definen, usa price_cents de Supabase
MERCADOPAGO_PRICE_ESTUDIO=15000
MERCADOPAGO_PRICE_AVANZADO=37500

# Países soportados (separados por coma)
# AR=Argentina, BR=Brasil, CL=Chile, CO=Colombia, MX=México, PE=Perú, UY=Uruguay
MERCADOPAGO_SUPPORTED_COUNTRIES=AR,BR,CL,CO,MX,PE,UY

# ----------------------------------------------------------------------------
# PAYPAL (Global)
# ----------------------------------------------------------------------------
# Obtener de: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=AxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxX
PAYPAL_CLIENT_SECRET=ExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxX

# Modo: sandbox | live
PAYPAL_MODE=sandbox

# Webhook ID (se obtiene después de crear el webhook)
PAYPAL_WEBHOOK_ID=

# Moneda para planes PayPal (USD recomendado)
PAYPAL_CURRENCY_CODE=USD

# Product ID de PayPal (opcional; el script setup-plans lo crea si falta)
PAYPAL_PRODUCT_ID=

# ----------------------------------------------------------------------------
# STRIPE (Desactivado - mantener para futura reactivación)
# ----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=<stripe-secret-key>
# STRIPE_WEBHOOK_SECRET=<stripe-webhook-secret>
# STRIPE_PUBLIC_KEY=<stripe-public-key>

# ----------------------------------------------------------------------------
# URLs DE LA APLICACIÓN
# ----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# URLs de retorno después del pago
PAYMENT_SUCCESS_URL=http://localhost:5173/dashboard?payment=success
PAYMENT_CANCEL_URL=http://localhost:5173/pricing?payment=cancelled
PAYMENT_PENDING_URL=http://localhost:5173/dashboard?payment=pending

# ----------------------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
